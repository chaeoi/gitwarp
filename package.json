{
  "name": "cf-registry-accelerator",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:dockerhub": "wrangler pages dev public --binding REGISTRY=dockerhub --compatibility-date=2026-05-27",
    "dev:ghcr": "wrangler pages dev public --binding REGISTRY=ghcr --compatibility-date=2026-05-27",
    "deploy:dockerhub": "wrangler pages deploy public --project-name dhub",
    "deploy:ghcr": "wrangler pages deploy public --project-name ghcr"
  }
}
